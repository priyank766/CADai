# CADai Backend -- environment configuration
# Copy to .env and fill in real values.

# App
APP_NAME=CADai Backend
APP_VERSION=0.1.0
DEBUG=true

# CORS -- frontend origin (Vite dev server)
FRONTEND_URL=http://localhost:5173
OPENROUTER_API_KEY=
# Gemini / Google ADK
# Get a key at https://ai.google.dev/gemini-api/docs/api-key
# The engine bridges this to GOOGLE_API_KEY (which ADK reads) at import time.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash